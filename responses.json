    "{\"id\":\"open_text\",\"text\":\"Ачилова Фируза Ғуломовна\"}",
    "{\"id\":\"1\",\"text\":\"0–5 йил\"}",
    "{\"id\":\"1\",\"text\":\"Ҳа, албатта оширади\"}",
    "{\"id\":\"3\",\"text\":\"50% Sun'iy Intellekt, 50% инсон қарори бўлиши керак\"}",
